#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
#  tokentool — interactive multi-model token counter
# ─────────────────────────────────────────────────────────────
set -euo pipefail

API_BASE="http://141.98.197.246:6969"
API_ANTHROPIC="${API_BASE}/tokenize_anthropic"
API_GEMINI="${API_BASE}/tokenize_gemini"
API_GPT4O="${API_BASE}/tokenize_o"

# ── colors ───────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
RESET='\033[0m'

# ── helpers ──────────────────────────────────────────────────
extract_count() {
    local raw
    raw=$(<"$1")
    raw="${raw//,/}"
    raw=$(echo "$raw" | tr -d '[:space:]')
    if [[ "$raw" =~ ^[0-9]+$ ]]; then
        echo "$raw"
    else
        echo ""
    fi
}

fmt() {
    local n="$1"
    if [[ -n "$n" && "$n" =~ ^[0-9]+$ ]]; then
        printf "%'d" "$n" 2>/dev/null || printf "%d" "$n"
    else
        echo "ERROR"
    fi
}

# ── count tokens for a JSON payload, print one table ────────
# $1 = temp json file   $2 = display label (filename or "text input")
count_and_print() {
    local json_file="$1"
    local label="$2"

    local tmp_a tmp_g tmp_o
    tmp_a=$(mktemp)
    tmp_g=$(mktemp)
    tmp_o=$(mktemp)

    curl -s --max-time 120 -X POST "$API_ANTHROPIC" \
         -H "Content-Type: application/json" -d @"$json_file" > "$tmp_a" &
    curl -s --max-time 120 -X POST "$API_GEMINI" \
         -H "Content-Type: application/json" -d @"$json_file" > "$tmp_g" &
    curl -s --max-time 120 -X POST "$API_GPT4O" \
         -H "Content-Type: application/json" -d @"$json_file" > "$tmp_o" &
    wait

    local ca cg co
    ca=$(fmt "$(extract_count "$tmp_a")")
    cg=$(fmt "$(extract_count "$tmp_g")")
    co=$(fmt "$(extract_count "$tmp_o")")

    rm -f "$tmp_a" "$tmp_g" "$tmp_o"

    printf '  📄 %s\n' "$label"
    printf '  ╭─────────────┬────────────╮\n'
    printf '  │ %-11s │ %10s │\n' "Model" "Tokens"
    printf '  ├─────────────┼────────────┤\n'
    printf '  │ %-11s │ %10s │\n' "Anthropic" "$ca"
    printf '  │ %-11s │ %10s │\n' "Gemini"    "$cg"
    printf '  │ %-11s │ %10s │\n' "GPT-4o"    "$co"
    printf '  ╰─────────────┴────────────╯\n\n'
}

# ── build JSON from a file path ─────────────────────────────
json_from_file() {
    local file="$1"
    local out="$2"
    python3 -c "
import json, sys
with open(sys.argv[1], 'r', errors='replace') as f:
    print(json.dumps({'input_string': f.read()}))
" "$file" > "$out" 2>/dev/null
}

# ── build JSON from a string ────────────────────────────────
json_from_string() {
    local text="$1"
    local out="$2"
    python3 -c "
import json, sys
print(json.dumps({'input_string': sys.argv[1]}))
" "$text" > "$out" 2>/dev/null
}

# ── mode 1: scan all files in current directory ─────────────
mode_scan_all() {
    echo ""
    printf "  ${DIM}Scanning: %s${RESET}\n\n" "$(pwd)"

    local found=0
    local temp_json
    temp_json=$(mktemp)
    trap "rm -f '$temp_json'" RETURN

    shopt -s nullglob
    local files=(*)
    shopt -u nullglob

    if [[ ${#files[@]} -eq 0 ]]; then
        printf "  ${YELLOW}No files found in current directory.${RESET}\n\n"
        return
    fi

    for f in "${files[@]}"; do
        [[ -f "$f" ]] || continue
        found=1
        printf "  ${DIM}Counting: %s ...${RESET}\n" "$f"
        if json_from_file "$f" "$temp_json" && [[ -s "$temp_json" ]]; then
            count_and_print "$temp_json" "$f"
        else
            printf "  ${RED}⚠ Skipped (could not read): %s${RESET}\n\n" "$f"
        fi
    done

    if [[ $found -eq 0 ]]; then
        printf "  ${YELLOW}No regular files found in current directory.${RESET}\n\n"
    fi
}

# ── mode 2: user inputs file paths ──────────────────────────
mode_file_input() {
    echo ""
    printf "  ${DIM}Paste file paths (one per line, or space-separated).${RESET}\n"
    printf "  ${DIM}Press Enter on an empty line when done.${RESET}\n\n"
    printf "  ${CYAN}files ↓${RESET}\n"

    # ── phase 1: collect all paths silently ──
    local -a files=()
    while IFS= read -r line; do
        [[ -z "$line" ]] && break         # empty line = done

        # split line on whitespace to support multiple files per line
        for token in $line; do
            # expand ~ if present
            token="${token/#\~/$HOME}"
            files+=("$token")
        done
    done

    if [[ ${#files[@]} -eq 0 ]]; then
        printf "\n  ${YELLOW}No files entered.${RESET}\n\n"
        return
    fi

    # ── phase 2: validate and list ──
    local -a valid=()
    echo ""
    printf "  ${DIM}Validating %d path(s) ...${RESET}\n" "${#files[@]}"
    for f in "${files[@]}"; do
        if [[ -f "$f" ]]; then
            valid+=("$f")
            printf "  ${GREEN}✓${RESET} %s\n" "$f"
        else
            printf "  ${RED}✗ Not found: %s${RESET}\n" "$f"
        fi
    done

    if [[ ${#valid[@]} -eq 0 ]]; then
        printf "\n  ${YELLOW}No valid files to process.${RESET}\n\n"
        return
    fi

    # ── phase 3: count each file ──
    echo ""
    printf "  ${DIM}Counting tokens for %d file(s) ...${RESET}\n\n" "${#valid[@]}"

    local temp_json
    temp_json=$(mktemp)
    trap "rm -f '$temp_json'" RETURN

    for f in "${valid[@]}"; do
        printf "  ${DIM}Counting: %s ...${RESET}\n" "$(basename "$f")"
        if json_from_file "$f" "$temp_json" && [[ -s "$temp_json" ]]; then
            count_and_print "$temp_json" "$(basename "$f")"
        else
            printf "  ${RED}⚠ Skipped (could not read): %s${RESET}\n\n" "$f"
        fi
    done
}

# ── mode 3: user inputs raw text ────────────────────────────
mode_text_input() {
    echo ""
    printf "  ${DIM}Paste or type your text. End with Ctrl-D on a new line.${RESET}\n\n"
    printf "  ${CYAN}text>${RESET} "

    local text=""
    while IFS= read -r line; do
        text+="$line"$'\n'
    done

    if [[ -z "${text// /}" ]]; then
        printf "\n  ${YELLOW}No text entered.${RESET}\n\n"
        return
    fi

    local temp_json
    temp_json=$(mktemp)
    trap "rm -f '$temp_json'" RETURN

    # truncate display label
    local preview="${text:0:50}"
    preview="${preview//$'\n'/ }"
    [[ ${#text} -gt 50 ]] && preview="${preview}…"

    printf "\n  ${DIM}Counting ...${RESET}\n"
    if json_from_string "$text" "$temp_json" && [[ -s "$temp_json" ]]; then
        count_and_print "$temp_json" "\"${preview}\""
    else
        printf "  ${RED}⚠ Failed to encode input.${RESET}\n\n"
    fi
}

# ── main menu ────────────────────────────────────────────────
clear_line() { printf '\r\033[K'; }

show_banner() {
    echo ""
    printf "  ${BOLD}${CYAN}╭──────────────────────────────────╮${RESET}\n"
    printf "  ${BOLD}${CYAN}│${RESET}  ${BOLD}tokentool${RESET}  ${DIM}multi-model counter${RESET}  ${BOLD}${CYAN}│${RESET}\n"
    printf "  ${BOLD}${CYAN}╰──────────────────────────────────╯${RESET}\n"
    echo ""
    printf "  ${GREEN}1${RESET}  Scan all files in current dir\n"
    printf "  ${GREEN}2${RESET}  Enter file paths (paste multiple ok)\n"
    printf "  ${GREEN}3${RESET}  Count tokens from text input\n"
    echo ""
}

main() {
    show_banner

    printf "  ${CYAN}Choose mode [${BOLD}1${RESET}${CYAN}]:${RESET} "
    read -r choice
    choice="${choice:-1}"

    case "$choice" in
        1) mode_scan_all    ;;
        2) mode_file_input  ;;
        3) mode_text_input  ;;
        *)
            printf "\n  ${RED}Invalid choice: %s${RESET}\n\n" "$choice"
            exit 1
            ;;
    esac
}

main
