" ============================================================
" Tree-sitter folding
" ============================================================

set foldmethod=expr
set foldexpr=v:lua.vim.treesitter.foldexpr()
set foldenable
set foldlevel=99
set foldlevelstart=99
set foldcolumn=1

nnoremap <leader>zc zc
nnoremap <leader>zo zo
nnoremap <leader>za za
nnoremap <leader>zM zM
nnoremap <leader>zR zR

