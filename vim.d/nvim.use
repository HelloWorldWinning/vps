" Function to run rustfmt formatter
function! RustfmtFormat()
    if executable('rustfmt')
        try
            silent! undojoin | %!rustfmt --edition 2024  --emit stdout
        catch /.*/
            echohl ErrorMsg | echo "rustfmt formatting failed" | echohl None
        endtry
    endif
endfunction

" Updated WriteRust function to precisely preserve cursor position
function! WriteRust()
    " Save the current cursor position (line and column)
    let l:pos = getpos('.')
    " Call the rustfmt formatter
    call RustfmtFormat()
    " Write the buffer to file
    write
    " Restore the cursor position
    call setpos('.', l:pos)
endfunction

function! WriteQuitRust()
    call RustfmtFormat()
    write
    quit
endfunction

" Map custom commands for Rust files only
autocmd FileType rust cnoreabbrev <buffer> w :call WriteRust()<CR>
autocmd FileType rust cnoreabbrev <buffer> wq :call WriteQuitRust()<CR>



" Flash keybindings
nnoremap s <cmd>lua require("flash").jump()<cr>
xnoremap s <cmd>lua require("flash").jump()<cr>
onoremap s <cmd>lua require("flash").jump()<cr>

nnoremap S <cmd>lua require("flash").treesitter()<cr>
xnoremap S <cmd>lua require("flash").treesitter()<cr>
onoremap S <cmd>lua require("flash").treesitter()<cr>

" --- LSP Configuration ---
lua << EOF
-- Enable Pyright (uses the server config shipped by nvim-lspconfig)
-- vim.lsp.enable('pyright')

-- Optional: buffer-local keymaps only when LSP attaches
vim.api.nvim_create_autocmd('LspAttach', {
  callback = function(args)
    local opts = { buffer = args.buf }
    vim.keymap.set('n', 'gd', vim.lsp.buf.definition, vim.tbl_extend('force', opts, { desc = "Go to Definition" }))
    vim.keymap.set('n', 'K',  vim.lsp.buf.hover,      vim.tbl_extend('force', opts, { desc = "Show Hover Doc" }))
    vim.keymap.set('n', 'gr', vim.lsp.buf.references, vim.tbl_extend('force', opts, { desc = "Show References" }))
  end,
})
EOF






