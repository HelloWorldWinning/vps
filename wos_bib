#!/usr/bin/env bash
# Usage: bash parse_wos.sh <input.bib>
# Output: <input>_parsed.txt  — compact, LLM-friendly

set -euo pipefail

[[ $# -ne 1 ]] && { echo "Usage: $0 <file>"; exit 1; }
INPUT="$1"
[[ ! -f "$INPUT" ]] && { echo "Not found: $INPUT"; exit 1; }

OUTFILE="$(dirname "$INPUT")/$(basename "$INPUT" | sed 's/\.[^.]*$//')_parsed.txt"

python3 - "$INPUT" "$OUTFILE" << 'PY'
import re, sys

src, dst = sys.argv[1], sys.argv[2]
text = open(src, encoding="utf-8", errors="replace").read()

entries = re.split(r'\n(?=@)', text.strip())

FIELDS = [
    ("Author",      "AU"),
    ("Title",       "TI"),
    ("Year",        "YR"),
    ("Journal",     "JO"),
    ("DOI",         "DO"),
    ("Keywords",    "KW"),
    ("Times-Cited", "TC"),
    ("Abstract",    "AB"),
]

def grab(block, key):
    pat = re.compile(
        r'^\s*' + re.escape(key) + r'\s*=\s*\{(.*?)(?=\n\s*[\w][\w-]*\s*=|\n\}|\Z)',
        re.I | re.M | re.S
    )
    m = pat.search(block)
    if not m:
        return ""
    val = m.group(1)
    val = re.sub(r'\},?\s*$', '', val)
    val = re.sub(r'\s+', ' ', val).strip()
    val = val.replace('\\&', '&')
    return val

out_lines = []
count = 0
for entry in entries:
    entry = entry.strip()
    if not entry.startswith('@'):
        continue
    count += 1
    parts = [f"[{count}]"]
    for field, label in FIELDS:
        v = grab(entry, field)
        if v:
            parts.append(f"{label}: {v}")
    out_lines.append("\n".join(parts))

open(dst, "w", encoding="utf-8").write("\n\n".join(out_lines) + "\n")
print(f"Done: {count} entries -> {dst}")
PY
