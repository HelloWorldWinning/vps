#!/usr/bin/env bash

# Robust tar.xz compressor
#
# Usage:
#   bash compress_xz file/folder [file/folder ...]
#
# Output:
#   Single input:
#       input_name.tar.xz
#
#   Multiple inputs:
#       archive_YYYYMMDD_HHMMSS.tar.xz


set -euo pipefail


DEFAULT_LEVEL=6
READ_TIMEOUT=3


usage()
{
    echo "Usage:"
    echo "  $0 file/folder [file/folder ...]"
    echo
    echo "Examples:"
    echo "  $0 folder"
    echo "  $0 file"
    echo "  $0 folder1 file1 folder2"
    exit 1
}


# -----------------------------
# Require input
# -----------------------------
if [[ $# -eq 0 ]]; then
    usage
fi


# -----------------------------
# Ask compression level
# -----------------------------
LEVEL="$DEFAULT_LEVEL"

read -r -t "$READ_TIMEOUT" -p \
"Compression level (0-9, default $DEFAULT_LEVEL): " USER_LEVEL || true


if [[ "${USER_LEVEL:-}" =~ ^[0-9]$ ]]; then
    LEVEL="$USER_LEVEL"
fi


# -----------------------------
# Validate input paths
# -----------------------------
INPUTS=()

for item in "$@"; do

    if [[ ! -e "$item" ]]; then
        echo "ERROR: not found: $item"
        exit 1
    fi

    INPUTS+=("$item")

done


# -----------------------------
# Determine output filename
# -----------------------------
if [[ ${#INPUTS[@]} -eq 1 ]]; then

    # Single file/folder
    BASE_NAME="$(basename "${INPUTS[0]}")"

    OUTPUT="${BASE_NAME}.tar.xz"

else

    # Multiple files/folders
    OUTPUT="archive_$(date +%Y%m%d_%H%M%S).tar.xz"

fi


# Avoid overwriting existing archive
if [[ -e "$OUTPUT" ]]; then
    echo "ERROR: output already exists: $OUTPUT"
    exit 1
fi


echo
echo "======================================"
echo " Compression started"
echo " Compression level : $LEVEL"
echo " Output            : $OUTPUT"
echo
echo " Input:"
printf "   %s\n" "${INPUTS[@]}"
echo "======================================"
echo


# -----------------------------
# Compress
# -----------------------------
tar \
    --verbose \
    --create \
    --file=- \
    "${INPUTS[@]}" \
| xz \
    -T0 \
    -"${LEVEL}" \
    --verbose \
    > "$OUTPUT"


echo
echo "======================================"
echo " Compression completed"
echo " File : $OUTPUT"
echo " Size : $(du -h "$OUTPUT" | awk '{print $1}')"
echo "======================================"
