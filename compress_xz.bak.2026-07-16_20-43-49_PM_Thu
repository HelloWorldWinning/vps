#!/usr/bin/env bash

# Robust tar.xz compressor
#
# Usage:
#   bash compress_xz file folder file2 folder2 ...
#
# Then:
#   asks compression level
#   waits 3 seconds
#   default = 6

set -euo pipefail

DEFAULT_LEVEL=6
READ_TIMEOUT=3


usage()
{
    echo "Usage:"
    echo "  $0 file/folder [file/folder ...]"
    echo
    echo "Example:"
    echo "  $0 trading_system_v2.2_train_high/"
    echo "  $0 folder1 file1 folder2"
    exit 1
}


# -----------------------------
# Require input files/folders
# -----------------------------
if [[ $# -eq 0 ]]; then
    usage
fi


# -----------------------------
# Ask compression level
# -----------------------------
LEVEL="$DEFAULT_LEVEL"

read -r -t "$READ_TIMEOUT" -p \
"Compression level (0-9, default $DEFAULT_LEVEL): " USER_LEVEL || true


if [[ "${USER_LEVEL:-}" =~ ^[0-9]$ ]]; then
    LEVEL="$USER_LEVEL"
fi


# -----------------------------
# Validate paths
# -----------------------------
INPUTS=()

for item in "$@"; do

    if [[ ! -e "$item" ]]; then
        echo "ERROR: not found: $item"
        exit 1
    fi

    INPUTS+=("$item")

done


# -----------------------------
# Output name
# -----------------------------
NAME="archive_$(date +%Y%m%d_%H%M%S).tar.xz"


echo
echo "======================================"
echo " Compression started"
echo " Compression level : $LEVEL"
echo " Output            : $NAME"
echo
echo " Input:"
printf "   %s\n" "${INPUTS[@]}"
echo "======================================"
echo


# -----------------------------
# Compress
# -----------------------------
tar \
    --verbose \
    --create \
    --file=- \
    "${INPUTS[@]}" \
| xz \
    -T0 \
    -"${LEVEL}" \
    --verbose \
    > "$NAME"


echo
echo "======================================"
echo " Done"
echo " File : $NAME"
echo " Size : $(du -h "$NAME" | awk '{print $1}')"
echo "======================================"
