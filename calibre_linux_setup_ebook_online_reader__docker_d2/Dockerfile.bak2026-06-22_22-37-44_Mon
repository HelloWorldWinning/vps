FROM debian:12-slim

ARG CALIBRE_VERSION
ARG CALIBRE_ARCH=x86_64

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive
ENV CALIBRE_LIBRARY_PATH=/calibre-library
ENV EBOOK_DOWNLOAD_PATH=/books
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    python3 \
    wget \
    xz-utils \
    xdg-utils \
    libegl1 \
    libopengl0 \
    libxcb-cursor0 \
    libxcb-xinerama0 \
    libxkbcommon0 \
    libgl1-mesa-glx \
    libfreetype6 \
    libfontconfig1 \
    libxrender1 \
    libxext6 \
    libx11-6 \
    libnss3 \
    libxcomposite1 \
    libxrandr2 \
    libxtst6 \
    libxdamage1 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libasound2 \
    libatk1.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libexpat1 \
    libgcc-s1 \
    libgdk-pixbuf-2.0-0 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libpci3 \
    libpcre3 \
    libpixman-1-0 \
    libstdc++6 \
    libdrm2 \
    libgbm1 \
    && rm -rf /var/lib/apt/lists/*

COPY downloads/calibre-${CALIBRE_VERSION}-${CALIBRE_ARCH}.txz /tmp/calibre.txz

RUN set -eux; \
    if [[ -z "${CALIBRE_VERSION:-}" ]]; then \
        echo "CALIBRE_VERSION build arg is required" >&2; \
        exit 1; \
    fi; \
    mkdir -p /opt/calibre; \
    rm -rf /opt/calibre/*; \
    tar -xJf /tmp/calibre.txz -C /opt/calibre; \
    /opt/calibre/calibre_postinstall; \
    calibre --version; \
    rm -f /tmp/calibre.txz

RUN mkdir -p "$EBOOK_DOWNLOAD_PATH" "$CALIBRE_LIBRARY_PATH"

RUN calibre-server --manage-users -- add a a

EXPOSE 8080
