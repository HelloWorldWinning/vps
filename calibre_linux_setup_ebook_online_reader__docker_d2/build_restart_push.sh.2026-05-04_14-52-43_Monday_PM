#!/usr/bin/env bash
set -Eeuo pipefail

COMPOSE_FILE="/root/book_docker_d/docker-compose.yml"
IMAGE="oklove/calibre1"
BUILD_CONTEXT="/data/vps/calibre_linux_setup_ebook_online_reader__docker_d2"

CALIBRE_VERSION="${1:-}"

if [[ -z "$CALIBRE_VERSION" ]]; then
    echo "Usage: $0 <calibre_version>" >&2
    exit 2
fi

cd "$BUILD_CONTEXT"

timestamp="$(date +%Y%m%d%H%M%S)"
CANDIDATE_TAG="${IMAGE}:candidate-${CALIBRE_VERSION}-${timestamp}"
FINAL_TAG="${IMAGE}:latest"

normalize_version() {
    local raw="${1:-}"
    local version
    version=$(printf '%s' "$raw" | grep -oE '[0-9]+(\.[0-9]+)+' | head -n1 || true)

    if [[ -z "$version" ]]; then
        echo ""
        return 0
    fi

    local IFS='.'
    local -a parts
    read -r -a parts <<< "$version"

    printf "%03d.%03d.%03d" \
        "${parts[0]:-0}" \
        "${parts[1]:-0}" \
        "${parts[2]:-0}"
}

echo "Old image:"
OLD_IMAGE_ID="$(docker image inspect "$FINAL_TAG" --format '{{.Id}}' 2>/dev/null || true)"
echo "${OLD_IMAGE_ID:-none}"

echo "Building candidate image: $CANDIDATE_TAG"

# Hard outer timeout prevents endless Docker build hangs.
timeout 60m docker build \
    --pull \
    --build-arg CALIBRE_VERSION="$CALIBRE_VERSION" \
    -t "$CANDIDATE_TAG" \
    .

echo "Testing candidate image..."

candidate_output="$(docker run --rm "$CANDIDATE_TAG" calibre --version)"
candidate_version="$(printf '%s' "$candidate_output" | grep -oE '[0-9]+(\.[0-9]+)+' | head -n1 || true)"

expected_norm="$(normalize_version "$CALIBRE_VERSION")"
candidate_norm="$(normalize_version "$candidate_version")"

echo "Expected Calibre:  $CALIBRE_VERSION ($expected_norm)"
echo "Candidate Calibre: $candidate_version ($candidate_norm)"

if [[ -z "$candidate_norm" || "$candidate_norm" != "$expected_norm" ]]; then
    echo "Candidate image version test failed. Existing running container was not touched." >&2
    exit 1
fi

echo "Candidate image passed."

echo "Tagging candidate as $FINAL_TAG"
docker tag "$CANDIDATE_TAG" "$FINAL_TAG"

echo "Recreating Docker Compose service..."

# Safer than down/up because it avoids removing networks and keeps downtime shorter.
docker compose -f "$COMPOSE_FILE" up -d --force-recreate

echo "Pushing image..."
docker push "$FINAL_TAG"

echo "Cleaning old image if safe..."
NEW_IMAGE_ID="$(docker image inspect "$FINAL_TAG" --format '{{.Id}}')"

if [[ -n "$OLD_IMAGE_ID" && "$OLD_IMAGE_ID" != "$NEW_IMAGE_ID" ]]; then
    docker image rm "$OLD_IMAGE_ID" 2>/dev/null || true
fi

# Remove candidate tag after it has been retagged.
docker image rm "$CANDIDATE_TAG" 2>/dev/null || true

# Do not use --volumes here. It can delete unrelated unused volumes.
docker builder prune -f --filter "until=168h" || true

echo "Upgrade completed successfully."
