#!/usr/bin/env python3
"""
get_tc - Fetch citation counts for DOIs and sort entries by TC descending.

Usage:  get_tc a_file
  Reads each entry's DO: field, queries OpenAlex for cited_by_count,
  appends TC: <count> below DO:, re-sorts entries so [1] has the max TC,
  and overwrites the file in place.
"""

import sys, re, time, urllib.request, json

def parse_entries(text):
    """Split file into numbered entries."""
    parts = re.split(r'(?=^\[\d+\])', text.strip(), flags=re.MULTILINE)
    return [p.strip() for p in parts if p.strip()]

def extract_doi(entry):
    m = re.search(r'^DO:\s*(.+)', entry, re.MULTILINE)
    return m.group(1).strip() if m else None

def fetch_tc(doi, retries=3):
    """Get cited_by_count from OpenAlex (free, no key needed)."""
    url = f"https://api.openalex.org/works/https://doi.org/{doi}"
    headers = {"User-Agent": "get_tc/1.0 (mailto:user@example.com)"}
    for attempt in range(retries):
        try:
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read().decode())
                return data.get("cited_by_count", 0)
        except Exception as e:
            if attempt < retries - 1:
                time.sleep(1.5 * (attempt + 1))
            else:
                print(f"  ⚠  Failed for {doi}: {e}", file=sys.stderr)
                return 0

def inject_tc(entry, tc):
    """Insert or update TC: line right after DO: line."""
    # Remove existing TC line if present
    entry = re.sub(r'\nTC:\s*\d+', '', entry)
    # Insert TC after DO line
    entry = re.sub(r'(^DO:\s*.+)$', rf'\1\nTC: {tc}', entry, count=1, flags=re.MULTILINE)
    return entry

def strip_header(entry):
    """Remove the [N] header line, return body only."""
    return re.sub(r'^\[\d+\]\s*\n?', '', entry, count=1)

def main():
    if len(sys.argv) != 2:
        print("Usage: get_tc <file>", file=sys.stderr)
        sys.exit(1)

    filepath = sys.argv[1]
    with open(filepath, 'r', encoding='utf-8') as f:
        text = f.read()

    entries = parse_entries(text)
    if not entries:
        print("No entries found.", file=sys.stderr)
        sys.exit(1)

    results = []  # list of (tc, entry_body)

    for i, entry in enumerate(entries, 1):
        doi = extract_doi(entry)
        body = strip_header(entry)
        if doi:
            print(f"[{i}/{len(entries)}] {doi} ... ", end="", flush=True)
            tc = fetch_tc(doi)
            print(f"TC: {tc}")
            body = inject_tc(body, tc)
        else:
            print(f"[{i}/{len(entries)}] No DOI found, setting TC: 0")
            body = inject_tc(body, 0)
            tc = 0
        results.append((tc, body))
        time.sleep(0.2)  # polite rate limiting

    # Sort descending by TC
    results.sort(key=lambda x: x[0], reverse=True)

    # Rebuild file with new numbering
    lines = []
    for idx, (tc, body) in enumerate(results, 1):
        lines.append(f"[{idx}]\n{body}")

    with open(filepath, 'w', encoding='utf-8') as f:
        f.write("\n".join(lines) + "\n")

    print(f"\n✓ {len(results)} entries sorted by TC (descending) → {filepath}")

if __name__ == "__main__":
    main()
